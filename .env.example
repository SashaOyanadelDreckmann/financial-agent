# LLM
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Modelo (puede cambiar sin tocar código)
OPENAI_MODEL=gpt-4o-mini

# Opcional
OPENAI_TEMPERATURE=0.3

# Server / Web
WEB_ORIGIN=http://localhost:3001

# Auth sessions
SESSION_TTL_DAYS=7

# Dev-only endpoints (profile/intake injection)
# In production keep this false unless you also set DEV_ADMIN_TOKEN.
ENABLE_DEV_INJECTION=false
DEV_ADMIN_TOKEN=change-me
